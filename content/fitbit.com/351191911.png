,null,[0]]],[["https://lh3.googleusercontent.com/gTHiSLXbiZCO3sVc8Cb_kq7Hewqd61cKIgEnK6ss8kFtlABvDJNPEG_UvVRF_mn5ls_VwEe48pR3V2Q7oKLIlWZOljaMI-Iy1ig",["md-lt-only"],null,[580,580],null,null,null,null,[0]]]]]],[null,null,null,null,[null,"onRequest"]]]],6],["L - template_external_spacer [1776206877969]|IT(it)|2026-04-14 23:07:52",null,null,null,null,"gsins_8789_6233",null,null,null,null,null,[[null,null,"large"]],7],["Watches and Trackers - GHP Hero|IT(it)|2026-04-14 23:07:52",null,null,null,null,"gsins_6850_8004",null,null,null,null,null,[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[null,"w-and-t-ghp-hero",[null,"onRequest"],null,[null,null,null,null,null,null,null,"Riproduci"],[null,null,null,null,null,null,null,"Riproduci"],null,null,null,null,null,null,[[["https://lh3.googleusercontent.com/W5kLAa3oNOChcFwpz9_AnRI9GgV8QB7HoqBnTWZYbB1doh0y8LuCn0p7-foug2NVqtNiOhbGruQPkgkhFu_qDdgUHF0ztP8de1Q",["lg-gt-only"],null,[2784,2000],null,null,null,null,[0]]],[["https://lh3.googleusercontent.com/T0KXL8lZObnBfiiocBv4GFNTjoPupA_uXiEgMfqu8k-nWG2gUAKITF1woqg_shIzfF4M6LgXotykMJxruRpVamlypGt85d1yFoYZ",["md-lt-only"],null,[720,920],null,null,null,null,[0]]]],null,null,null,null,null,null,null,null,null,null,["left"],null,[null,null,null,null,[null,"onRequest"]],null,[null,null,[null,"google_health"],null,[null,[null,"Un approccio innovativo per prenderti cura di te."],"display-medium"],[null,[null,"L\u0026#39;app Fitbit è ora l\u0026#39;app Google Health. Con l\u0026#39;abbonamento Premium potrai accedere alla funzionalità di coaching personalizzato realizzato con Gemini."]],null,[null,null,[[null,[null,"ds-mid-emphasis-grey"],[null,"Esplora Google Health Premium","Esplora Google Health Premium"],[[null,"/product/google_health_premium"]]]]]]]],8],["XS - template_external_spacer [1776206877969-7]|IT(it)|2026-04-14 23:07:52",null,null,null,null,"gsins_4911_9775",null,null,null,null,null,[[null,null,"extra-small"]],9],["Watches and Trackers - Gemini Coaching Feature|IT(it)|2026-04-14 23:07:52",null,null,null,null,"gsins_2973_1546",null,null,null,null,null,[null,null,null,null,null,["w-and-t-gemini-coaching",null,null,null,null,null,null,null,null,[null,[null,"Muoviti per guadagnare più equipaggiamento."]],["left"],null,null,null,null,null,null,null,null,[null,null,null,null,[null,[null,"Progettata con Gemini per offrirti corsi di fitness, sonno e salute adatti ai tuoi obiettivi e alla tua vita."],"display-small"]]]],10],["L - template_external_spacer [1776206877969-11]|IT(it)|2026-04-14 23:07:52",null,null,null,null,"gsins_1034_3317",null,null,null,null,null,[[["background-gradient","background-gradient-FFFFFF","background-gradient-EFFFFE"],null,"extra-large"]],11],["Watches and Trackers - GHP features|IT(it)|2026-04-16 00:05:07",null,null,null,null,"gsins_3869_9729",null,null,null,null,null,[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,["w-and-t-coaching-cases",[null,null,[null,null,"#EFFFFE"]],null,["fixed-height","mid","long"],[[null,null,[[["https://lh3.googleusercontent.com/pbTeI7pWDVKAf_-rJPcqbMl-KDEsNKdL1Qa60qnojG_ELopKZ45Fx-lHXHBDOfZ3MJ9XXGg4KhfNRFl7NNlIha9U5dIvRZdHpM0",["lg-gt-only"],"Interfaccia di chat con Google Health Coach su sfondo astratto verde acqua, accompagnata dalla foto di una persona che corre all\u0026#39;aperto. Il messaggio di un utente dice: \u0026quot;Sono in viaggio questa settimana e non avrò accesso a una palestra\u0026quot;. L\u0026#39; Coach risponde: \u0026quot;Portati con te le scarpe da corsa! Cambierò i tuoi due allenamenti al coperto con quelli di corsa all\u0026#39;aperto\u0026quot;.",[1200,1400],null,null,null,null,[0]]],[["https://lh3.googleusercontent.com/u0KoFVMhpfjQVYmUPqGffnrfDlo0B2pArgo5PRBNRjZQ6kbGIsYLXa9huGMfGLekePjYtCtE0Lp6VKlsk9jAwAxcSesm5UXDcA",["md-lt-only","rounded-corners","disable-loop"],"Interfaccia di chat con Google Health Coach su sfondo astratto verde acqua, accompagnata dalla foto di una persona che corre all\u0026#39;aperto. Il messaggio di un utente dice: \u0026quot;Sono in viaggio questa settimana e non avrò accesso a una palestra\u0026quot;. L\u0026#39; Coach risponde: \u0026quot;Portati con te le scarpe da corsa! Cambierò i tuoi due allenamenti al coperto con quelli di corsa all\u0026#39;aperto\u0026quot;.",[592,740],null,null,null,null,[0]]]],null,[null,null,null,null,[null,[null,"Una guida che si adatta sempre ai tuoi progressi."],"headline-medium"],[null,[null,"Tutto inizia con una conversazione. Specifica le tue preferenze e le tue routine, e Google Health Coach seguirà le tue indicazioni per creare piani di allenamento a lungo termine e dare consigli su come migliorare la qualità del sonno, giorno per giorno.\u003csup data-footnote\u003d\"ghp\"\u003e\u003c/sup\u003e"]]]],[null,null,[[["https://lh3.googleusercontent.com/SW8-5JjIGKXqHJqWEX_8Xn-BQ7r7fhfRY6H0d14VcYy-5Jvqz2FOkls2W8gIEr6Ety0kGaOBije5xFlqz6E6oZtnmLG3flBcH0g",["lg-gt-only"],"Interfaccia di chat con Google Health Coach su sfondo viola. Mostra la foto di una persona che guarda il telefono seduta su un divano. Il messaggio Coach dice \u0026quot;Sei sveglio da poco più di 1 ora e 32 min, un valore superiore al solito\u0026quot;, seguito da una barra di monitoraggio del sonno che indica \u0026quot;Sveglio - 17%\u0026quot;.",[1200,1400],null,null,null,null,[0]]],[["https://lh3.googleusercontent.com/3kUL1s67gTFyk7LU0jffgshFa-ya4xxB-6XZ-NXFTKcuJDb7komu7CoTmf29pr3k8GeyTMH7rK2hCGY4O8oqx9wQmLQ-9zuLuqg",["md-lt-only","rounded-corners","disable-loop"],"Interfaccia di chat con Google Health Coach su sfondo viola. Mostra la foto di una persona che guarda il telefono seduta su un divano. Il messaggio Coach dice \u0026quot;Sei sveglio da poco più di 1 ora e 32 min, un valore superiore al solito\u0026quot;, seguito da una barra di monitoraggio del sonno che indica \u0026quot;Sveglio - 17%\u0026quot;.",[592,740],null,null,null,null,[0]]]],null,[null,null,null,null,[null,[null,"Piani di allenamento in linea con i tempi di riposo e recupero di cui hai bisogno."],"headline-medium"],[null,[null,"Ogni giorno è diverso. Ricevi consigli che ti aiutano a trovare la motivazione nei momenti difficili, come quando devi adattare il sonno al fuso orario o recuperare dopo un infortunio.\u003csup data-footnote\u003d\"ghp\"\u003e\u003c/sup\u003e"]]]],[null,null,[[["https://lh3.googleusercontent.com/nrU__VMCSXe-wVnVCAdoTQLBW3hxEy8iaEX1791pCAeABW963azK4BNoIYWQpZ9cSJs4P5Aol88wPdu1v5fZ31doC8yQSQ7aJEHv",["lg-gt-only"],"Un\u0026#39;interfaccia chat con Google Health Coach su sfondo astratto azzurro. Un messaggio utente chiede: \u0026quot;Ho sentito che la variabilità del battito cardiaco è una buona indicazione di salute. Come va?\u0026quot; accanto a una foto di una persona che controlla il suo smartwatch. The Coach risponde: \u0026quot;Con un aumento costante HRV negli ultimi tre mesi, i tuoi dati ci dicono quello che vogliamo sentire\u0026quot;. Di seguito è riportato un grafico che mostra una variabilità del battito cardiaco di 52 ms rilevando il valore \u0026quot;Nel raggio d\u0026#39;azione\u0026quot; nei giorni della settimana.",[1200,1400],null,null,null,null,[0]]],[["https://lh3.googleusercontent.com/8WdlPJMH4RzQOz7_OIuEPqapYgqejdv7xMi1QQB9I5J1F7bnEaf7FN0Zz6ubKX6omUMPR2iVt7mhswxtvOFxhNfhgDxfI_Poj0g",["md-lt-only"],"Un\u0026#39;interfaccia chat con Google Health Coach su sfondo astratto azzurro. Un messaggio utente chiede: \u0026quot;Ho sentito che la variabilità del battito cardiaco è una buona indicazione di salute. Come va?\u0026quot; accanto a una foto di una persona che controlla il suo smartwatch. The Coach risponde: \u0026quot;Con un aumento costante HRV negli ultimi tre mesi, i tuoi dati ci dicono quello che vogliamo sentire\u0026quot;. Di seguito è riportato un grafico che mostra una variabilità del battito cardiaco di 52 ms rilevando il valore \u0026quot;Nel raggio d\u0026#39;azione\u0026quot; nei giorni della settimana.",[592,740],null,null,null,null,[0]]]],null,[null,null,null,null,[null,[null,"Suggerimenti proattivi per la tua salute."],"headline-medium"],[null,[null,"Sei tu a stabilire la visione. Google Health Coach ti supporta con consigli basati su una visione olistica del tuo stato di salute, che si tratti di individuare le tendenze principali o festeggiare i tuoi successi.\u003csup data-footnote\u003d\"ghp\"\u003e\u003c/sup\u003e ,\u003csup data-footnote\u003d\"may-vary\"\u003e\u003c/sup\u003e"]]]]],"Schede con cursore"]],12],["L - template_external_spacer [1776206877969 - 17]|IT(it)|2026-04-16 00:05:07",null,null,null,null,"gsins_1931_1500",null,null,null,null,null,[[["background-gradient","background-gradient-EFFFFE","background-gradient-FFFFFF"],null,"large"]],13],["Watches and Trackers - SC Partnership|IT(it)|2026-04-14 23:07:52",null,null,null,null,"gsins_8095_5088",null,null,null,null,null,[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[null,"w-and-t-steph-curry",null,null,null,[[["https://lh3.googleusercontent.com/J2myjRClBqEJFEjSKuqsZ1hrB_OQQ9211ei_CzWuTT0a3ImSi75cfjGvMBcrYUp3dPqfxDW7iD54f13jN528JQdsTJouAQF-OWTD",["lg-gt-only","round-corners"],"Stephen Curry che indossa una felpa con cappuccio senza maniche nera, guarda lontano dall\u0026#39;inquadratura mentre tiene un pallone da bas